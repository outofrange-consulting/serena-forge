{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "-p",
        "3.13",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "${CLAUDE_PLUGIN_ROOT}/contexts/serena-forge.yml",
        "--open-web-dashboard",
        "False"
      ]
    }
  }
}
